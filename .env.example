# Trust Platform — environment variables
# Copy to .env and fill in what you need. All variables are optional except where noted.

# ── Server ──────────────────────────────────────────────────────────────────
PORT=3000

# ── Database (optional — JSONL fallback if not set) ─────────────────────────
# DATABASE_URL=postgresql://user:password@localhost:5432/trust_platform

# ── API Authentication (optional — open if not set) ──────────────────────────
# Comma-separated list of valid keys. Set this in production.
# API_KEYS=sk-trust-abc123,sk-trust-def456

# ── Google Sheets (optional — local JSON files used if not set) ───────────────
# GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id
# GOOGLE_APPLICATION_CREDENTIALS=./path/to/service-account-key.json
# SHEETS_CACHE_MS=60000

# ── Redis (optional — caching + velocity tracking) ────────────────────────────
# REDIS_URL=redis://localhost:6379
# CACHE_FRAUD_TTL_SEC=300
# CACHE_DEVICE_TTL_SEC=600

# ── Analytics ────────────────────────────────────────────────────────────────
# AMPLITUDE_API_KEY=your_amplitude_api_key

# ── AI Copilot ────────────────────────────────────────────────────────────────
# ANTHROPIC_API_KEY=your_anthropic_api_key

# ── Intelligence adapters (Phase 2) ──────────────────────────────────────────
# ip-api.com and GreyNoise community: no key needed, always active
# ABUSEIPDB_API_KEY=      # free at abuseipdb.com (1000 checks/day)
# HIBP_API_KEY=           # ~$3.50/month at haveibeenpwned.com/API

# ── Auth / WebAuthn ──────────────────────────────────────────────────────────
SESSION_SECRET=change-me-in-production
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=Signal Trust Platform
WEBAUTHN_ORIGIN=http://localhost:3000
SITE_URL=http://localhost:3000
# Production values:
# WEBAUTHN_RP_ID=trustdecision.letsinvent.co.uk
# WEBAUTHN_ORIGIN=https://trustdecision.letsinvent.co.uk
# SITE_URL=https://trustdecision.letsinvent.co.uk

# ── SMTP (optional — magic links returned in API response in dev mode) ─────────
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=user@example.com
# SMTP_PASS=yourpassword
# SMTP_FROM=noreply@trustdecision.letsinvent.co.uk

# ── Live traffic daemon (Phase 3) ─────────────────────────────────────────────
# TRAFFIC_DAEMON_API_KEY=sk-trust-daemon-internal   # must match an entry in API_KEYS
# ENABLE_ATTACKS=true                               # set false to disable scheduled attack scenarios
# ATTACK_INTERVAL_MS=1800000                        # credential stuffing interval (default 30 min)
# ENABLE_ATTACK_TRIGGERS=true                       # expose POST /dev/attack/:scenario endpoint
