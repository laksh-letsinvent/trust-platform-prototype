# Optional: use Google Sheets as data source (users, devices, actions, authenticators).
# If not set, the app uses JSON files in ./data/
# GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id
# GOOGLE_APPLICATION_CREDENTIALS=./path/to/service-account-key.json
# GOOGLE_SHEETS_CREDENTIALS_PATH=./path/to/service-account-key.json
# SHEETS_CACHE_MS=60000

# Redis (optional, for caching fraud/device scores)
# REDIS_URL=redis://localhost:6379

# Amplitude (optional, for product analytics)
# Get your API key from: Amplitude → Settings → Projects → default → API Key
# AMPLITUDE_API_KEY=your_amplitude_api_key
