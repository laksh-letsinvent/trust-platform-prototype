{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "version":         { "type": "string" },
    "description":     { "type": "string" },
    "default_vendor":  { "type": "string" },
    "active_strategy": { "type": "string" },
    "strategies": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["type"],
        "properties": {
          "type":        { "type": "string" },
          "description": { "type": "string" }
        }
      }
    }
  },
  "additionalProperties": true
}
